# 正式站：复制到 /etc/nginx/sites-available/ 并 ln -s 到 sites-enabled
# 上游：本机 Next 3000、FastAPI 8000（与 deploy/systemd 正式单元一致）
#
# www.theyuanxi.cn — main site
server {
    listen 443 ssl http2;
    server_name www.theyuanxi.cn;
    ssl_certificate     /etc/nginx/ssl/theyuanxi.cn.fullchain.crt;
    ssl_certificate_key /etc/nginx/ssl/theyuanxi.cn.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    client_max_body_size 10m;
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;
    proxy_read_timeout 120s;
    proxy_connect_timeout 10s;
    proxy_send_timeout 120s;

    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Admin-Token $http_x_admin_token;
    }

    location = /MP_verify_qyRmLUsICdwsMTNB.txt {
        alias /app/frontend/public/MP_verify_qyRmLUsICdwsMTNB.txt;
        default_type text/plain;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
