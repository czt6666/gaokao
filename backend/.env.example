# ============================================================
# 袁希高报引擎 · 后端环境变量示例
# 复制为 backend/.env 后按需填写；.env 已加入 .gitignore 勿提交。
# ============================================================


# ── 站点 ────────────────────────────────────────────────────
# 站点根 URL（支付回调、CORS、链接生成、微信授权跳转等）
SITE_URL=https://www.theyuanxi.cn


# ── 数据库 ───────────────────────────────────────────────────
# 默认自动定位至 database.py 同目录下的 gaokao.db，无需修改。
# 若需指定绝对路径（例如多站点共用不同库）：
# DATABASE_URL=sqlite:////app/mega/backend/gaokao.db


# ── 后台管理 ─────────────────────────────────────────────────
# 后台页面与管理 API 的访问 Token，务必改掉默认值
ADMIN_TOKEN=


# ── JWT ─────────────────────────────────────────────────────
# 用户登录 Token 签名密钥，生产环境必须换成随机长字符串
JWT_SECRET=


# ── 短信（腾讯）─────────────────────────────
# 腾讯云 SMS
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN=
TENCENT_SMS_TEMPLATE_ID=

# 阿里云薪资数据 API AppCode（scrapers/aliyun_salary_api.py）
ALIYUN_APPCODE=


# ── 微信 ─────────────────────────────────────────────────────
# 公众号（网页授权登录、二维码轮询等）
WECHAT_SERVICE_APP_ID=
WECHAT_SERVICE_APP_SECRET=

# 小程序
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=

# 微信支付
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
WECHAT_CERT_SERIAL=
WECHAT_PRIVATE_KEY_PATH=
WECHAT_PUBKEY_PATH=
WECHAT_NOTIFY_URL=


# ── 支付宝 ───────────────────────────────────────────────────
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=


# ── 邮件 ─────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# 运营通知收件邮箱（新订单/异常等推送）
NOTIFY_EMAIL=


# ── AI / LLM ─────────────────────────────────────────────────
# Anthropic Claude（若填写则优先使用；留空则回退到 DeepSeek）
ANTHROPIC_API_KEY=
# DeepSeek（志愿 AI 解析、10年预测等）
DEEPSEEK_API_KEY=


# ── 调试 & 性能 ──────────────────────────────────────────────
# 详细日志（1=开启，0=关闭；生产建议 0）
GAOKAO_DEBUG=0

# 预热缓存启动延迟（秒，默认 5）
# GAOKAO_PREWARM_DELAY_SEC=5

# 预热缓存每批次休眠（秒，默认 0.5；降低防止启动时打满 CPU）
# GAOKAO_PREWARM_SLEEP_SEC=0.5

# 预热仅处理免费省份（1=是，适合本地开发快速启动）
# GAOKAO_PREWARM_FREE=0
