# 安装: sudo cp gaokao-staging-backend.service.example /etc/systemd/system/gaokao-staging-backend.service
# 首次: cd /app/mega/backend && python3 -m venv .venv && .venv/bin/pip install -r requirements.txt
# 在 /app/mega/backend/.env 中设置 SITE_URL=https://mega.theyuanxi.cn（及其它密钥）
# 然后: sudo systemctl daemon-reload && sudo systemctl enable --now gaokao-staging-backend

[Unit]
Description=Gaokao API (staging / mega.theyuanxi.cn)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/app/mega/backend
Environment=PYTHONUNBUFFERED=1
ExecStart=/app/mega/backend/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8100
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
