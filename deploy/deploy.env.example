# 复制为 deploy/deploy.env 后按需修改（deploy.env 已加入 .gitignore 勿提交密钥）
#
# SSH 登录目标，例如 root@你的服务器IP
SSH_TARGET=root@43.143.206.19

# ── 正式版（www / theyuanxi.cn）── 与现有单机目录一致时可保持默认
PROD_REMOTE_ROOT=/app
PROD_SYSTEMD_BACKEND=gaokao-backend
PROD_SYSTEMD_FRONTEND=gaokao-frontend

# ── 测试版（mega.theyuanxi.cn）── 独立目录 + 独立端口，与正式版进程隔离
STAGING_REMOTE_ROOT=/app/mega
STAGING_SYSTEMD_BACKEND=gaokao-staging-backend
STAGING_SYSTEMD_FRONTEND=gaokao-staging-frontend

# 正式部署前是否要求手动输入 yes（1=开启，避免误触 prod）
PROD_CONFIRM=1
